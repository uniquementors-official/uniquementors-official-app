# Database (Supabase PostgreSQL Connection Pooler)
DATABASE_URL="postgresql://postgres.your-project-id:your-db-password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?connection_limit=3"
DIRECT_URL="postgresql://postgres.your-project-id:your-db-password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?connection_limit=3"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-32-chars-long"

# Supabase (SupaDB Integration)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_API_KEY="your-supabase-api-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_REGION="ap-northeast-2"

# Cloudinary (Optional fallback)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (Resend)
